---
// CommandsTable — renders the CLI command inventory FROM the generated data.
// Source of truth: docs/src/generated/mage-data.json (regenerated by
// `pnpm docs:gen`, guarded by the vitest drift test). Never hand-type rows here.
//
// Props:
//   showHidden (boolean, default false) — when true, also render the hidden
//     "plumbing" commands in a separate grouping below the public ones.
import data from '../generated/mage-data.json';

interface Props {
  showHidden?: boolean;
}

const { showHidden = false } = Astro.props;

const all = data.commands;
const visible = all.filter((c) => !c.hidden);
const hidden = all.filter((c) => c.hidden);

const groups = showHidden
  ? [
      { title: null, commands: visible },
      { title: 'Plumbing (hidden) commands', commands: hidden },
    ]
  : [{ title: null, commands: visible }];
---

{
  groups.map((group) =>
    group.commands.length === 0 ? null : (
      <div>
        {group.title ? <h3>{group.title}</h3> : null}
        {group.commands.map((cmd) => (
          <div class="mage-command">
            <h4>
              <code>mage {cmd.name}</code>
              {cmd.hidden ? (
                <span class="mage-plumbing-badge">plumbing</span>
              ) : null}
            </h4>
            <p>{cmd.summary}</p>
            {cmd.aliases.length > 0 ? (
              <p>
                <strong>Aliases:</strong>{' '}
                {cmd.aliases.map((a) => (
                  <code>{a}</code>
                ))}
              </p>
            ) : null}
            {cmd.options.length > 0 ? (
              <div class="mage-table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Flag</th>
                      <th>Description</th>
                    </tr>
                  </thead>
                  <tbody>
                    {cmd.options.map((opt) => (
                      <tr>
                        <td><code>{opt.flags}</code></td>
                        <td>{opt.description}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <p>
                <em>No options.</em>
              </p>
            )}
          </div>
        ))}
      </div>
    ),
  )
}
