---
// ThresholdsTable — renders the threshold + sensitivity-dial tables FROM the
// generated data. Source of truth: docs/src/generated/mage-data.json
// (regenerated by `pnpm docs:gen`, guarded by the vitest drift test).
import data from '../generated/mage-data.json';

const { rows, sensitivities, defaultSensitivity, minChapterWorkEvents } =
  data.thresholds;

const levels = ['low', 'normal', 'high'] as const;
---

<div class="mage-table-wrap">
  <table>
    <thead>
      <tr>
        <th>Symbol / key</th>
        <th>Value</th>
        <th>Dial-scaled</th>
        <th>Meaning</th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((r) => (
          <tr>
            <td>
              {r.symbol ? <strong>{r.symbol}</strong> : null}
              <code>{r.key}</code>
            </td>
            <td><code>{String(r.value)}</code></td>
            <td>{r.dialScaled ? 'yes' : 'no'}</td>
            <td>{r.meaning}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<p>
  The <strong>sensitivity dial</strong> scales the two recurrence gates
  (<strong>K</strong> = <code>promoteSessions</code>,
  <strong>M</strong> = <code>graduateSessions</code>). Default sensitivity:
  <code>{defaultSensitivity}</code>. A chapter counts toward recurrence only
  once it has at least <code>{minChapterWorkEvents}</code> work events.
</p>

<div class="mage-table-wrap">
  <table>
    <thead>
      <tr>
        <th>Sensitivity</th>
        <th>K (<code>promoteSessions</code>)</th>
        <th>M (<code>graduateSessions</code>)</th>
      </tr>
    </thead>
    <tbody>
      {
        levels.map((level) => (
          <tr>
            <td>
              <code>{level}</code>
              {level === defaultSensitivity ? ' (default)' : ''}
            </td>
            <td><code>{sensitivities[level].promoteSessions}</code></td>
            <td><code>{sensitivities[level].graduateSessions}</code></td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
