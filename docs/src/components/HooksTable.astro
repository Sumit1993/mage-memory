---
// HooksTable — renders the capture-hook inventory FROM the generated data.
// Source of truth: docs/src/generated/mage-data.json (regenerated by
// `pnpm docs:gen`, guarded by the vitest drift test). Never hand-type rows here.
import data from '../generated/mage-data.json';

const hooks = data.hooks;
---

<div class="mage-table-wrap">
  <table>
    <thead>
      <tr>
        <th>Event</th>
        <th>Hook id</th>
        <th>Command</th>
        <th>Purpose</th>
      </tr>
    </thead>
    <tbody>
      {
        hooks.map((h) => (
          <tr>
            <td><code>{h.event}</code></td>
            <td><code>{h.id}</code></td>
            <td><code>{h.command}</code></td>
            <td>{h.purpose}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
