# docs/ is a SELF-CONTAINED sub-project, not a member of the root pnpm workspace.
# Always install from inside docs/ with `pnpm install --ignore-workspace` so pnpm
# does not walk up to the repo root and inherit the root .npmrc / lockfile.
#
# The native-dependency build allow-list (esbuild, which rides Astro's Vite)
# lives in pnpm-workspace.yaml under `onlyBuiltDependencies` (the pnpm 11 home for
# that setting). Astro's image pipeline uses the passthrough/noop service here, so
# no sharp native build is required for the build to be green.
auto-install-peers=true

# This sandbox enforces a higher-precedence supply-chain policy that denies ALL
# dependency build scripts, so esbuild's/sharp's postinstall are skipped even
# though esbuild is allow-listed. Those packages ship prebuilt platform binaries
# (and Astro uses the noop image service, so sharp is unused), so the skipped
# scripts are harmless. strict-dep-builds=false keeps a skipped build a WARNING
# instead of the fatal ERR_PNPM_IGNORED_BUILDS, so `pnpm install` exits 0 in CI.
strict-dep-builds=false
